# claude-discord bridge — local config

# === REQUIRED ===

# Discord bot token. Generate at:
#   https://discord.com/developers/applications -> your app -> Bot -> Reset Token
BRIDGE_DISCORD_BOT_TOKEN=

# YOUR Discord user ID (numeric, 18-19 digits) — only this user can use the
# bridge; everyone else's DMs are silently dropped. To get it:
#   Discord -> User Settings -> Advanced -> Developer Mode (on)
#   then tap your own profile -> Copy User ID.
BRIDGE_ALLOWED_USER_ID=

# === OPTIONAL ===

# Working directory passed to `claude` (`cwd`). Defaults to your home dir.
# Claude Code resolves CLAUDE.md, hooks, and project context from here.
# BRIDGE_WORKDIR=/home/you/code/myproject

# Path to the `claude` binary. Auto-detected via `which claude` if unset.
# Override if you have multiple installs or a non-PATH location.
# BRIDGE_CLAUDE_BIN=/home/you/.local/bin/claude

# === Unified multi-agent bridge (unified_bridge.py) ===
# Runs multiple Discord bot accounts in one process. No private IDs are defaulted.
# BRIDGE_AGENTS=claude_agent,codex_agent
# BRIDGE_ATTACHMENT_DIR=/Users/you/.discord-agent-bridge/attachments

# Claude-backed bot account
# CLAUDE_AGENT_TOKEN=
# CLAUDE_AGENT_BACKEND=claude
# CLAUDE_AGENT_ALLOWED_USER_ID=
# CLAUDE_AGENT_WORKDIR=/Users/you/Projects
# CLAUDE_AGENT_CLAUDE_BIN=/Users/you/.local/bin/claude
# CLAUDE_AGENT_DEFAULT_MODEL=sonnet
# CLAUDE_AGENT_DEFAULT_EFFORT=high
# CLAUDE_AGENT_CLAUDE_PERMISSION_MODE=bypassPermissions
# CLAUDE_AGENT_ALIASES=claudette,claude

# Codex-backed bot account
# CODEX_AGENT_TOKEN=
# CODEX_AGENT_BACKEND=codex
# CODEX_AGENT_ALLOWED_USER_ID=
# CODEX_AGENT_WORKDIR=/Users/you/Projects
# CODEX_AGENT_CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex
# CODEX_AGENT_DEFAULT_MODEL=gpt-5.5
# CODEX_AGENT_DEFAULT_EFFORT=xhigh
# CODEX_AGENT_DEFAULT_SANDBOX=workspace-write
# CODEX_AGENT_DEFAULT_SEARCH=off
# CODEX_AGENT_ALIASES=luna,codex

# Optional shared-channel routing per agent. For shared channels, prefix messages
# with an alias like `luna: ...` or `claudette: ...` so only that bot responds.
# CLAUDE_AGENT_ALLOWED_CHANNEL_IDS=
# CLAUDE_AGENT_ALLOWED_BOT_USER_IDS=
# CODEX_AGENT_ALLOWED_CHANNEL_IDS=
# CODEX_AGENT_ALLOWED_BOT_USER_IDS=
