# claude-discord-bridge — local configuration
#
# This file is loaded automatically by both bot.py and unified_bridge.py
# from the directory the script runs in (it uses python-dotenv). For
# production we recommend keeping the real env file OUTSIDE the repo
# (e.g. ~/.config/unified-discord-bridge/env) and feeding it via a
# systemd EnvironmentFile= directive — see examples/.
#
# Two run modes are supported:
#   1. bot.py            — single bot, single backend. Uses BRIDGE_* vars
#                          (REQUIRED + OPTIONAL sections below).
#   2. unified_bridge.py — multiple bot accounts in one process,
#                          optionally with a manager bot orchestrating
#                          worker bots. Uses BRIDGE_AGENTS plus per-agent
#                          prefixed vars (UNIFIED MULTI-AGENT BRIDGE
#                          section below).
#
# Pick one. Don't mix.

# =============================================================================
# REQUIRED — single-bot mode (bot.py)
# =============================================================================

# Discord bot token. Generate at:
#   https://discord.com/developers/applications → your app → Bot → Reset Token
BRIDGE_DISCORD_BOT_TOKEN=

# YOUR Discord user ID (numeric, 18-19 digits). Only this user can use the
# bridge; everyone else's DMs are silently dropped.
#   Discord → User Settings → Advanced → Developer Mode (on)
#   then tap your own profile → Copy User ID.
BRIDGE_ALLOWED_USER_ID=

# =============================================================================
# OPTIONAL — single-bot mode (bot.py)
# =============================================================================

# Working directory passed to `claude`. Defaults to your home dir.
# Claude Code resolves CLAUDE.md, hooks, and project context from here.
# BRIDGE_WORKDIR=/home/you/code/myproject

# Path to the `claude` binary. Auto-detected via `which claude` if unset.
# BRIDGE_CLAUDE_BIN=/home/you/.local/bin/claude


# =============================================================================
# UNIFIED MULTI-AGENT BRIDGE — unified_bridge.py
# =============================================================================
#
# Run multiple Discord bot accounts in a single Python process, sharing
# attachment storage and event loop. Each agent is an independent bot
# token + backend pair.
#
# The variable name layout is BRIDGE_AGENTS (a list) plus, for each entry
# in that list, prefixed vars derived from the entry name uppercased and
# safe-charactered. Example: BRIDGE_AGENTS=worker_a,worker_b yields the
# prefixes WORKER_A_ and WORKER_B_.

# Comma- or space-separated list of agent names. Required when running
# unified_bridge.py.
# BRIDGE_AGENTS=worker_a,worker_b

# Where inbound Discord attachments are downloaded for the workers to
# read. Per-agent ATTACHMENT_DIR overrides this. Created on first use.
# BRIDGE_ATTACHMENT_DIR=/home/you/.cache/discord-agent-bridge/attachments

# -----------------------------------------------------------------------------
# Per-agent config — repeat this block for each name in BRIDGE_AGENTS.
# Replace <PREFIX> with the uppercased agent name.
# -----------------------------------------------------------------------------

# REQUIRED:
#
#   <PREFIX>_TOKEN              Discord bot token for THIS bot account.
#                               Falls back to <PREFIX>_DISCORD_BOT_TOKEN.
#   <PREFIX>_BACKEND            "codex" or "claude".
#   <PREFIX>_ALLOWED_USER_ID    Your numeric Discord user ID. Required even
#                               if ACCEPT_DMS=false (kept for forward-compat
#                               and for slash-command authorization).
#
# Codex-backed agents also require <PREFIX>_CODEX_BIN if `codex` is not on
# PATH. Claude-backed agents likewise need <PREFIX>_CLAUDE_BIN if `claude`
# is not on PATH.

# OPTIONAL (per agent):
#
#   <PREFIX>_WORKDIR              cwd for the backend subprocess. Default $HOME.
#   <PREFIX>_ATTACHMENT_DIR       Override BRIDGE_ATTACHMENT_DIR for this agent.
#   <PREFIX>_DEFAULT_MODEL        Initial model. Override at runtime with /model.
#   <PREFIX>_DEFAULT_EFFORT       Initial effort level. Override with /effort.
#   <PREFIX>_DEFAULT_SANDBOX      [codex only] read-only | workspace-write |
#                                 danger-full-access. Default workspace-write.
#   <PREFIX>_DEFAULT_SEARCH       [codex only] on | off. Default off.
#   <PREFIX>_CLAUDE_PERMISSION_MODE
#                                 [claude only] bypassPermissions | default.
#                                 Default bypassPermissions (auto-mode on).
#   <PREFIX>_ALIASES              Names this bot answers to in shared channels.
#                                 Comma- or space-separated. Default: the
#                                 agent name itself.
#   <PREFIX>_ALLOWED_CHANNEL_IDS  Channels where both you and authorized bots
#                                 may speak. Comma- or space-separated IDs.
#   <PREFIX>_ALLOWED_BOT_USER_IDS Other bots whose messages this agent honors
#                                 in allowed channels. Used for manager-bot
#                                 orchestration.
#   <PREFIX>_BOT_ONLY_CHANNEL_IDS Channels where the human user is IGNORED
#                                 entirely; only senders in ALLOWED_BOT_USER_IDS
#                                 are processed. Use this on a worker bot in
#                                 an orchestration channel.
#   <PREFIX>_ACCEPT_DMS           true | false. Default true. Set false on a
#                                 worker bot when only the manager bot should
#                                 ever talk to it.

# -----------------------------------------------------------------------------
# Example — two-bot setup, no manager
# -----------------------------------------------------------------------------
# BRIDGE_AGENTS=worker_a,worker_b
# BRIDGE_ATTACHMENT_DIR=/home/you/.cache/discord-agent-bridge/attachments
#
# WORKER_A_TOKEN=...
# WORKER_A_BACKEND=claude
# WORKER_A_ALLOWED_USER_ID=123456789012345678
# WORKER_A_WORKDIR=/home/you/code
# WORKER_A_DEFAULT_MODEL=sonnet
# WORKER_A_ALIASES=worker_a,wa
#
# WORKER_B_TOKEN=...
# WORKER_B_BACKEND=codex
# WORKER_B_ALLOWED_USER_ID=123456789012345678
# WORKER_B_WORKDIR=/home/you/code
# WORKER_B_DEFAULT_MODEL=gpt-5.5
# WORKER_B_DEFAULT_SANDBOX=workspace-write
# WORKER_B_ALIASES=worker_b,wb

# -----------------------------------------------------------------------------
# Example — manager-bot orchestration (third bot drives the workers in a
# shared channel; the human only DMs the manager)
# -----------------------------------------------------------------------------
# In the orchestration channel <ORCH_CHANNEL_ID>, only the manager bot
# (<MANAGER_BOT_USER_ID>) is allowed to address the workers. Each worker
# is configured to ignore your DMs and accept manager bot messages only.
# Manager bot itself is NOT defined here — it's typically a separate
# process (your own orchestrator, an OpenClaw agent, another instance of
# unified_bridge.py with backend=codex/claude pointed at a third token).
#
# BRIDGE_AGENTS=worker_a,worker_b
# BRIDGE_ATTACHMENT_DIR=/home/you/.cache/discord-agent-bridge/attachments
#
# WORKER_A_TOKEN=...
# WORKER_A_BACKEND=claude
# WORKER_A_ALLOWED_USER_ID=123456789012345678
# WORKER_A_ACCEPT_DMS=false
# WORKER_A_BOT_ONLY_CHANNEL_IDS=<ORCH_CHANNEL_ID>
# WORKER_A_ALLOWED_BOT_USER_IDS=<MANAGER_BOT_USER_ID>
# WORKER_A_ALIASES=worker_a
#
# WORKER_B_TOKEN=...
# WORKER_B_BACKEND=codex
# WORKER_B_ALLOWED_USER_ID=123456789012345678
# WORKER_B_ACCEPT_DMS=false
# WORKER_B_BOT_ONLY_CHANNEL_IDS=<ORCH_CHANNEL_ID>
# WORKER_B_ALLOWED_BOT_USER_IDS=<MANAGER_BOT_USER_ID>
# WORKER_B_ALIASES=worker_b
